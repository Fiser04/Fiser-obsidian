\title{\textbf{Document Databases: The Complete Deep Dive}\\\vspace{0.3cm}\large A Comprehensive Study Guide for Computer Science Students\\Transitioning from MSSQL/PostgreSQL to the Document Paradigm}
\author{CS Advanced Database Systems Study Guide}
